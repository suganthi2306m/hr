PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/livetrack_web
JWT_SECRET=replace_with_secure_jwt_secret

# Required for browser clients. Comma-separated, no spaces after commas (spaces break CORS matching).
# Example: http://localhost:5173,http://localhost:5174,https://hr-gamma-two.vercel.app
# When NODE_ENV is not production, localhost Vite ports (5173–5199, etc.) are also allowed automatically.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Optional: Vercel project name(s) — allows https://<slug>.vercel.app and preview https://<slug>-*.vercel.app
# without listing every preview URL in CORS_ORIGIN. Comma-separated, case-insensitive.
# When unset, defaults include customerconnect and hr-gamma-two. Set explicitly to restrict, e.g. only your app:
# CORS_VERCEL_SLUGS=hr-gamma-two

NODE_ENV=production
# When NODE_ENV=production locally, set to 1 to log 5xx stack + Paysharp err.raw in the API terminal (src/server.js).
# VERBOSE_API_ERRORS=1

# Optional — password reset emails (see src/services/emailService.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

MOBILE_INGEST_KEY=
TASK_COLLECTION=

DEFAULT_ADMIN_NAME=LiveTrack Admin
DEFAULT_ADMIN_EMAIL=h@gmail.com
DEFAULT_ADMIN_PASSWORD=web123

# Optional — platform super admin (sees /super in the web app). Restart API after changing.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
LICENSE_PRODUCT_PREFIX=LT

# -----------------------------------------------------------------------------
# Platform billing & payment gateways (Super Admin can also store secrets in Mongo)
# Routes: POST /api/company/subscription/initiate | initiate-razorpay
#         GET  …/plans | …/current | …/payments
#         POST /api/subscription/webhook/razorpay | …/paysharp (raw body for Razorpay signature)
# -----------------------------------------------------------------------------

# Optional: AES key for encrypting integration secrets in Mongo (defaults to SHA-256 of JWT_SECRET if unset).
# PLATFORM_SECRETS_KEY=

# Public web origin for Razorpay payment-link callback and mock checkout redirects (fallback: first CORS_ORIGIN).
# FRONTEND_URL=http://localhost:5173
# WEB_APP_URL=http://localhost:5173

# If > 0, subscription amount is forced to this many paise (testing only).
# PAYMENT_TEST_AMOUNT_PAISE=0

# If 1, skips real Paysharp/Razorpay calls and returns a mock checkout URL on billing.
# PAYMENT_DEV_MOCK_CHECKOUT=1

# --- Razorpay (env wins over DB; see platformGatewayConfig.getRazorpayConfig) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Paysharp (see paysharpService.js, platformGatewayConfig.getPaysharpConfig) ---
# linkpayment (default): sandbox …/api/v1/upi/linkpayment — hosted payment link (different product than UPI Intent).
# intent: BizzPass-style UPI — POST https://api.paysharp.in/v1/upi/order/intent → upi:// intentUrl as checkoutUrl.
# PAYSHARP_CHECKOUT_MODE=linkpayment
# PAYSHARP_CHECKOUT_MODE=intent

# Link Payment API origin (sandbox vs live). Ignored when PAYSHARP_CHECKOUT_MODE=intent (UPI base below is used).
# PAYSHARP_API_BASE_URL=
# PAYSHARP_SANDBOX_API_BASE_URL=
# PAYSHARP_LIVE_API_BASE_URL=

# UPI Intent / QR API base. If unset: live → api.paysharp.in/v1/upi; “Use sandbox” on → sandbox.paysharp.co.in/api/v1/upi.
# PAYSHARP_UPI_API_BASE_URL=https://api.paysharp.in/v1/upi

# Long dashboard token: prefer PAYSHARP_API_TOKEN / PAYSHARP_BEARER_TOKEN (wins over PAYSHARP_SECRET_KEY when both set).
# Short “api key” + PAYSHARP_SECRET_KEY often 401 on UPI Intent — use one long token in API_TOKEN, or only SECRET_KEY with long value.
# Do not put the webhook signing secret in PAYSHARP_API_TOKEN — that value is only for verifying callbacks, not Bearer on payment APIs.
# PAYSHARP_SECRET_KEY=
# PAYSHARP_API_TOKEN=
# PAYSHARP_BEARER_TOKEN=

# Link payment: 10-digit fallback mobile when company has no phone (digits only).
# PAYSHARP_DEFAULT_CUSTOMER_MOBILE=

# Link validity in hours (1–1440; default 168 = 7 days).
# PAYSHARP_LINK_VALIDITY_HOURS=168

# Local debugging ONLY: logs decrypted API token, webhook secret, merchant id, full Paysharp request/response.
# Remove or set 0 before any shared/staging/production deploy. (paysharpService.js + subscriptionController.js)
# PAYSHARP_DEBUG_LOG=1
