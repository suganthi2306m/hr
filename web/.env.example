# Copy to `.env` for local. On Vercel, set Production (and Preview if needed) env vars there.
#
# Dashboard → web_backend only (not customerconnect-mobile-api).
# Vercel Production example:
#   VITE_API_BASE_URL=https://customerconnect-web-api.onrender.com/api
#   VITE_SOCKET_URL=https://customerconnect-web-api.onrender.com
#
# Local `npm run dev`: even if VITE_API_BASE_URL points at Render, the app uses
# http://localhost:5000/api unless you set:
#   VITE_DEV_USE_REMOTE_API=1
#
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_MAPS_API_KEY=

# Attendance ops: wall clock + day range use this IANA zone (default Asia/Kolkata).
# Use `local` or `browser` to interpret times in the machine's timezone instead.
# VITE_ATTENDANCE_TIMEZONE=Asia/Kolkata
